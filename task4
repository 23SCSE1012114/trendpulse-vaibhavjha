import pandas as pd
import matplotlib.pyplot as plt

df = pd.read_csv("cleaned_trends.csv")

top_words = df['trend'].value_counts().head(10)

plt.figure(figsize=(10, 5))
top_words.plot(kind='bar')
plt.title("Top Trending Topics")
plt.xlabel("Trend")
plt.ylabel("Count")
plt.xticks(rotation=45)
plt.tight_layout()
plt.show()
